# Server
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/database_name
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_this_to_a_very_long_random_256bit_secret_string
JWT_REFRESH_SECRET=change_this_to_a_different_very_long_random_secret_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AWS S3 (use DO Spaces-compatible config if using DigitalOcean)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_S3_BUCKET=vertexfx-kyc-documents
AWS_S3_REGION=us-east-1

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@vertexfx.com
SENDGRID_FROM_NAME=VertexFX

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Flutterwave
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret

# Paystack
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# KYC Providers (choose one or both)
ONFIDO_API_TOKEN=your_onfido_api_token
SMILE_IDENTITY_API_KEY=your_smile_key
SMILE_IDENTITY_PARTNER_ID=your_partner_id

# Encryption (AES-256 — must be exactly 32 characters)
ENCRYPTION_KEY=change_this_32char_encryption_key

# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5